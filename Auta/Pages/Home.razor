
@page "/"

<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>

<div class="row">

    <!-- Levá část -->
    <div class="col-6">

        @foreach (var kategorie in listKategorii)
        {
            <h2>
                @kategorie.NazevKategorie
                <button class="btn btn-danger" @onclick="() => SmazatKategorii(kategorie)">Zmazat kategorii</button>
            </h2>

            <div class="row mb-4">

                @foreach (var komponenta in kategorie.Komponenty)
                {
                    <div class="col-6 mb-2">

                        <div class="card">
                            <div class="card-body">

                                <strong>@komponenta.Nazev</strong>
                                <br />
                                @komponenta.Popis

                                <br />
                                <br />

                                @if (!komponenta.Zakoupeno)
                                {
                                    <button class="btn btn-success"
                                            disabled="@(kategorie.JedenVyber && kategorie.Komponenty.Any(x => x.Zakoupeno))"
                                            @onclick="() => Zakoupit(komponenta)">
                                        Přidat
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-danger"
                                            @onclick="() => OdebratZKosiku(komponenta)">
                                        Odebrat
                                    </button>
                                }
                                <button class="btn btn-danger" @onclick="() => SmazatKomponentu(kategorie, komponenta)">
                                    Smazat
                                </button>

                            </div>
                        </div>

                    </div>
                }

            </div>
        }

    </div>

    <!-- Pravá část -->
    <div class="col-6">

        <h2>
            Vybraná výbava
        </h2>
        <h3>
            Celková cena: @CelkovaCenaZakoupenych() Kč
        </h3>

        <ul class="list-group">

            @foreach (var komponenta in listKoupenych)
            {
                <li class="list-group-item">

                    <div>
                        <strong>@komponenta.Nazev</strong>
                        <br />
                        @komponenta.Popis
                        <br />
                        <strong>Cena: @komponenta.Cena Kč</strong>
                    </div>

                    <button class="btn btn-danger btn-sm"
                            @onclick="() => OdebratZKosiku(komponenta)">
                        Odebrat
                    </button>

                </li>
            }

        </ul>

        <br />

        <h4>Editační režim</h4>

        @if(!editace)
        {

        <button class="btn btn-danger mb-3"
                @onclick="() => editace = !editace">
                 Editační režim
        </button>
        }

        @if (editace)
        {
      
            <button class="btn btn-danger mb-3"
                    @onclick="() => editace = !editace">
               Vypnout Editační režim
            </button>
        

        <div class="card">
            <div class="card-body">



                <h5>Správa kategorií</h5>

                <div class="mb-3">

                    <div class="col-12">
                        <input class="form-control" placeholder="Název nové kategorie" @bind-value="novaKategorie.NazevKategorie" />
                    </div>

                    <div class="col-12">
                        <InputSelect class="form-select" @bind-value="novaKategorie.JedenVyber">
                            <option value="true">Povolit pouze jeden výběr </option>
                            <option value="false">Povolit více výběrů</option>
                        </InputSelect>
                    </div>

                    <div class="col-12">
                        <button class="btn btn-primary" @onclick="PridatKategorii">
                            Přidat
                        </button>
                    </div>

                </div>

                <h5>Správa komponent</h5>

                <div class="row">

                    <div class="col-12">
                        <InputSelect class="form-select" @bind-value="novaKomponenta.Nazev">
                            @foreach (var kategorie in listKategorii)
                            {
                                <option value="@kategorie.NazevKategorie">@kategorie.NazevKategorie</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="col-12">
                        <input class="form-control" placeholder="Popis komponenty" @bind-value="novaKomponenta.Popis" />
                    </div>

                    <div class="col-12">
                        <input class="form-control" type="number" placeholder="Cena" @bind-value="novaKomponenta.Cena" />
                    </div>

                    <div class="col-12">
                        <button class="btn btn-primary" @onclick="PridatKomponentu">
                            Přidat
                        </button>
                    </div>

                </div>

            </div>
        </div>
        }
    </div>

</div>




@code
{
    List<Models.Kategorie> listKategorii = new List<Models.Kategorie>();
    List<Models.Komponenty> listKoupenych = new List<Models.Komponenty>();
    

    Models.Kategorie novaKategorie = new Models.Kategorie();
    Models.Komponenty novaKomponenta = new Models.Komponenty();

    private bool editace = false;


    override protected void OnInitialized()
    {
        listKategorii.Add(new Models.Kategorie { NazevKategorie = "Motor", JedenVyber = true });
        listKategorii.Add(new Models.Kategorie { NazevKategorie = "Karoserie", JedenVyber = true });
        listKategorii.Add(new Models.Kategorie { NazevKategorie = "Kola", JedenVyber = true });
        listKategorii.Add(new Models.Kategorie { NazevKategorie = "Bezpečnostní systémy", JedenVyber = false });

        listKategorii[0].Komponenty.Add(new Models.Komponenty { Nazev = "1.0 TSI", Popis = "Úsporný", Cena = 50000});
        listKategorii[0].Komponenty.Add(new Models.Komponenty { Nazev = "1.5 TSI", Popis = "Méně úsporný", Cena = 60000 });
        listKategorii[0].Komponenty.Add(new Models.Komponenty { Nazev = "1.6 TDI", Popis = "Nafta", Cena = 55000 });
        listKategorii[0].Komponenty.Add(new Models.Komponenty { Nazev = "1.4 TFSI", Popis = "Nic", Cena = 45000 });

        listKategorii[1].Komponenty.Add(new Models.Komponenty { Nazev = "Hatchback", Popis = "5 dveří", Cena = 100000 });
        listKategorii[1].Komponenty.Add(new Models.Komponenty { Nazev = "Sedan", Popis = "4 dveře", Cena = 120000 });
        listKategorii[1].Komponenty.Add(new Models.Komponenty { Nazev = "Kombi", Popis = "5 dveří", Cena = 130000 });
        listKategorii[1].Komponenty.Add(new Models.Komponenty { Nazev = "Coupe", Popis = "2 dveře", Cena = 150000 });

        listKategorii[2].Komponenty.Add(new Models.Komponenty { Nazev = "R16", Popis = "16 palců", Cena = 5000 });
        listKategorii[2].Komponenty.Add(new Models.Komponenty { Nazev = "R17", Popis = "17 palců", Cena = 6000 });
        listKategorii[2].Komponenty.Add(new Models.Komponenty { Nazev = "R18", Popis = "18 palců", Cena = 7000 });
        listKategorii[2].Komponenty.Add(new Models.Komponenty { Nazev = "R19", Popis = "19 palců", Cena = 8000 });

        listKategorii[3].Komponenty.Add(new Models.Komponenty { Nazev = "Hlídání mrtvého úhlu", Popis = "Zvýší bezpečnost při řízení", Cena = 10000 });
        listKategorii[3].Komponenty.Add(new Models.Komponenty { Nazev = "Parkovací senzory", Popis = "Pomůže při parkování", Cena = 15000 });
        listKategorii[3].Komponenty.Add(new Models.Komponenty { Nazev = "Adaptivní tempomat", Popis = "Udržuje nastavenou rychlost a vzdálenost od vozidla před vámi", Cena = 20000 });
        listKategorii[3].Komponenty.Add(new Models.Komponenty { Nazev = "Asistent pro jízdu v pruzích", Popis = "Pomáhá udržovat vozidlo v jízdním pruhu", Cena = 25000 });
        listKategorii[3].Komponenty.Add(new Models.Komponenty { Nazev = "Systém nouzového brzdění", Popis = "Automaticky zabrzdí, pokud detekuje hrozící kolizi", Cena = 30000 });



    }

    private void Zakoupit(Models.Komponenty komponenta)
    {
        komponenta.Zakoupeno = true;
        listKoupenych.Add(komponenta);
    }

    private void OdebratZKosiku(Models.Komponenty komponenta)
    {
        komponenta.Zakoupeno = false;
        listKoupenych.Remove(komponenta);
    }


    private void SmazatKategorii(Models.Kategorie kategorie)
    {
        // Odebereme všechny komponenty z této kategorie z košíku
        foreach (var komponenta in kategorie.Komponenty)
        {
            if (komponenta.Zakoupeno)
            {
                OdebratZKosiku(komponenta);
            }
        }
        // Poté smažeme kategorii
        listKategorii.Remove(kategorie);
    }

    private int CelkovaCenaZakoupenych()
    {
        return listKoupenych.Sum(k => k.Cena);
    }

    private void PridatKategorii()
    {
        if (!string.IsNullOrWhiteSpace(novaKategorie.NazevKategorie))
        {
            listKategorii.Add(new Models.Kategorie
            {
                NazevKategorie = novaKategorie.NazevKategorie,
                JedenVyber = novaKategorie.JedenVyber
            });
            novaKategorie = new Models.Kategorie(); // Resetujeme formulář
        }
    }


    private void PridatKomponentu()
    {
        if (!string.IsNullOrWhiteSpace(novaKomponenta.Nazev) && novaKomponenta.Cena > 0)
        {
            var kategorie = listKategorii.FirstOrDefault(k => k.NazevKategorie == novaKomponenta.Nazev);
            if (kategorie != null)
            {
                kategorie.Komponenty.Add(new Models.Komponenty
                {
                    Nazev = novaKomponenta.Nazev,
                    Popis = novaKomponenta.Popis,
                    Cena = novaKomponenta.Cena
                });
                novaKomponenta = new Models.Komponenty(); // Resetujeme formulář
            }
        }
    }


    private void SmazatKomponentu(Models.Kategorie kategorie, Models.Komponenty komponenta)
    {
        if (komponenta.Zakoupeno)
            OdebratZKosiku(komponenta);

        kategorie.Komponenty.Remove(komponenta);
    }


















}